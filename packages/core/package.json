{
  "name": "p4client-ts",
  "version": "0.3.1",
  "description": "Typed TypeScript helpers for the Perforce p4 CLI",
  "license": "MIT",
  "author": "peculiarnewbie",
  "keywords": [
    "perforce",
    "p4",
    "cli",
    "typescript",
    "version-control",
    "scm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/peculiarnewbie/p4client-ts.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/peculiarnewbie/p4client-ts/issues"
  },
  "homepage": "https://p4client-ts.peculiarnewbie.com",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/*.test.ts",
    "test:e2e": "bun test tests/e2e",
    "docs:api": "typedoc --options typedoc.json",
    "docs:api:check": "typedoc --options typedoc.json",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "bun run clean && bun run typecheck && bun run build"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.37"
  },
  "engines": {
    "node": ">=18"
  }
}
