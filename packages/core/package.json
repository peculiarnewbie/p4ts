{
  "name": "p4-ts",
  "version": "0.1.0",
  "description": "Typed TypeScript helpers for the Perforce p4 CLI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/*.test.ts",
    "test:e2e": "bun test tests/e2e",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "bun run clean && bun run typecheck && bun run build"
  },
  "dependencies": {
    "effect": "4.0.0-beta.33"
  },
  "engines": {
    "node": ">=18"
  }
}
