{
  "name": "p4-ts-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "effect-language-service patch typescript",
    "build": "bun run --cwd packages/core build",
    "typecheck": "bun run --cwd packages/core typecheck",
    "test": "bun run --cwd packages/core test",
    "test:e2e": "bun run --cwd packages/core test:e2e",
    "docs:dev": "bun run --cwd packages/www dev",
    "docs:build": "bun run --cwd packages/www build",
    "docs:check": "bun run --cwd packages/core docs:api:check && bun run --cwd packages/www check && bun run --cwd packages/www build",
    "clean": "bun run --cwd packages/core clean",
    "pack:core": "bun run --cwd packages/core pack:check",
    "publish": "cd packages/core && npm publish"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/starlight": "^0.38.2",
    "@effect/language-service": "^0.85.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.6.0",
    "astro": "^6.0.8",
    "starlight-typedoc": "^0.21.5",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.2"
  }
}
